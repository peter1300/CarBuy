VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_ADMIN_EMAIL=admin@example.com

# Cloudflare Stream API Worker (see workers/stream-api/README.md)
# Local: http://127.0.0.1:8787  |  Deployed: https://cbuy-stream-api.<account>.workers.dev
VITE_STREAM_API_URL=http://127.0.0.1:8787

# Supabase Dashboard → Authentication → URL Configuration:
# Site URL = https://car-buy-kappa.vercel.app
# Redirect URLs = https://car-buy-kappa.vercel.app/**  and  http://localhost:5173/**

# Run SQL migrations in order (SQL Editor):
# supabase/migrations/001_init.sql … 020_cloudflare_stream.sql
# After 012, set admin email in Supabase (must match VITE_ADMIN_EMAIL):
#   update public.app_settings set value = 'you@example.com' where key = 'admin_email';
# After 014: existing listings default to country HU; set browse prefs in Settings.
# After 020–021: Cloudflare Stream UIDs + listing still images (listing-images bucket).
